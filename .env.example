# Google Maps JavaScript API key (browser). Required to render the map.
# Create at https://console.cloud.google.com -> APIs & Services -> Credentials.
# Enable "Maps JavaScript API". Restrict the key to your domain(s).
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Optional: override the published Google Sheet (pubhtml/CSV) document id.
# This is the City of Pittsburgh "Mill & Pave List" published-to-web id.
PAVING_SHEET_PUB_ID=2PACX-1vRf8IJiGqX_ZK1j4YP1sq3YIOvxAvKq3kZpcaqlBVdl_yvfrLjQKCocWIDH5xNIJA

# Optional: override the WPRDC DOMI Street Closures ("construction" layer)
# datastore resource id. Defaults to the current active resource.
DOMI_CLOSURES_RESOURCE_ID=a9a1d93a-9d3b-4c18-bd80-82ed6f86404a

# Optional: override the PennDOT "PA Projects" ArcGIS service and the county the
# "PennDOT projects" layer is restricted to. Defaults to Allegheny County.
PENNDOT_PROJECTS_URL=https://gis.penndot.gov/arcgis/rest/services/paprojects/paprojects/MapServer
PENNDOT_PROJECTS_COUNTY=ALLEGHENY

# "Road closures" layer (PennDOT RCRS road events). Source is selectable:
#   511  (default) = open 511PA site, no key.
#   rcrs           = official RCRS Event Data API (liveEvents/plannedEvents).
#                    Falls back to 511 until RCRS_EVENTS_URL + creds are set,
#                    and on any request failure.
PENNDOT_EVENTS_SOURCE=511
# Open 511PA base. Events are gated to Allegheny County's actual boundary
# (data/allegheny-boundary.json) via a point-in-polygon test, so closures just
# over the line in neighboring counties are dropped. PENNDOT_EVENTS_BBOX is an
# optional cheap pre-filter box "south,west,north,east" (defaults to the
# boundary's bounding box); it can widen the box but never loosens the polygon.
PENNDOT_511_URL=https://www.511pa.com
# PENNDOT_EVENTS_BBOX=40.18,-80.36,40.68,-79.69
# Official RCRS Event Data API (request a free data feed at
# https://www.pa.gov/services/penndot/request-access-to-transportation-related-data-feeds).
# Set PENNDOT_EVENTS_SOURCE=rcrs once these are filled in.
# RCRS_EVENTS_URL=            # base url of the RCRS_Event_Data service (no trailing slash)
# RCRS_USERNAME=
# RCRS_PASSWORD=
# RCRS_EVENTS_METHODS=liveEvents,plannedEvents
